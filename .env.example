# =============================================================================
# Synthetic covenant-model demo — container configuration
# =============================================================================
# Every value below has a working demo default baked into the image, so the
# container runs with NO env file at all. Override only what you need (e.g. a
# host that injects its own PORT). SYNTHETIC DATA ONLY — do not point any of
# these at real data. No secrets belong in this file or in the image.
#
# (apps/web/.env.example documents the web app's own local-dev variables; this
#  root file is the container/deploy surface.)

# Public port the Next.js server listens on (managed hosts often inject PORT).
PORT=3000

# Internal port for the deterministic Python engine. Bound to 127.0.0.1 inside
# the container only; never exposed publicly.
AGREEMENT_ENGINE_PORT=8765

# Persistence backend. Only "sqlite" is implemented; the app refuses any other
# value. (A Postgres schema exists under /supabase/migrations but has no
# adapter and is intentionally NOT used for this single-container demo.)
AGREEMENT_DATA_BACKEND=sqlite

# Absolute path to the SQLite database file. Point this INSIDE the mounted
# volume so data survives restarts. Default matches the volume mount below.
AGREEMENT_SQLITE_PATH=/app/apps/web/.data/agreement-intelligence.db

# Enables seeding the tracked synthetic manifest. Safe to leave true for this
# synthetic-only demo; the seed refuses any non-synthetic manifest.
AGREEMENT_ALLOW_SYNTHETIC_SEED=true

# Path to the synthetic demo manifest the seed loads.
AGREEMENT_SYNTHETIC_MANIFEST=/app/workspaces/demo/manifest.json

# Server-to-server URL the web app uses to reach the engine (localhost-internal).
AGREEMENT_ENGINE_API_URL=http://127.0.0.1:8765

# Seconds the entrypoint waits for the engine /health probe before failing.
ENGINE_HEALTH_TIMEOUT=60
